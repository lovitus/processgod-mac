      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "This account is not allowed to control the system daemon." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "当前账户无权控制系统守护进程。" } }
      }
    },
    "error.notBootstrapped": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The system daemon has not completed owner setup." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "系统守护进程尚未完成所有者设置。" } }
      }
    },
    "error.invalidCron": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The Cron expression is invalid." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "Cron 表达式无效。" } }
      }
    },
    "error.duplicateID": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "A process with this stable ID already exists." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "此固定 ID 已被其他进程使用。" } }
      }
    },
    "error.notFound": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The requested process no longer exists." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "请求的进程已不存在。" } }
      }
    },
    "error.daemonDegraded": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The daemon is running but its configuration needs repair." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "守护进程正在运行，但配置需要修复。" } }
      }
    },
    "error.daemonUnavailable": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The guardian daemon is not available." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "守护进程当前不可用。" } }
      }
    },
    "error.invalidResponse": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The daemon returned an invalid IPC response." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "守护进程返回了无效的 IPC 响应。" } }
      }
    },
    "error.protocolMismatch": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The app and daemon IPC versions are incompatible." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "应用与守护进程的 IPC 版本不兼容。" } }
      }
    },
    "error.helperMissing": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "The Go helper is missing from the application bundle." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "应用包中缺少 Go helper。" } }
      }
    },
    "error.migrationFailed": {
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Service migration failed and the previous service was restored." } },
        "zh-Hans": { "stringUnit": { "state": "translated", "value": "服务迁移失败，已恢复原服务。" } }
      }
    },
    "error.revisionConflict": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Configuration changed elsewhere. The latest version has been reloaded."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "配置已被其他操作修改，已重新加载最新版本。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
